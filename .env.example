# --- Lead email: use Resend on Railway (HTTPS, no SMTP) ---
RESEND_API_KEY=
# Verified sender, e.g. Bold Crow <leads@yourdomain.com>
RESEND_FROM_EMAIL=

# Where inbound lead notifications go (required for any email path)
LEAD_NOTIFICATION_EMAIL=

# --- Or use SMTP instead (omit or leave RESEND_API_KEY empty) ---
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=
# SMTP_USE_SSL=true

MCP_BASE_URL=http://localhost:8000
APP_ENV=development
# LOG_LEVEL=INFO
